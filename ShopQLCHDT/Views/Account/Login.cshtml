@{
    ViewBag.Title = "Đăng nhập";
}

<!-- Login Page -->
<section style="min-height: calc(100vh - 80px); display: flex; align-items: center; justify-content: center; padding: 2rem 0;">
    <div class="neon-container" style="max-width: 480px;">
        <div class="glass-card animate-fade-in">
            <!-- Header -->
            <div style="text-align: center; margin-bottom: 2rem;">
                <div style="width: 70px; height: 70px; margin: 0 auto 1.5rem; background: var(--gradient-neon); border-radius: var(--radius-xl); display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-person" style="font-size: 2rem; color: var(--color-void);"></i>
                </div>
                <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">
                    Đăng nhập
                </h1>
                <p style="color: var(--text-secondary);">
                    Chào mừng bạn trở lại! Vui lòng đăng nhập để tiếp tục.
                </p>
            </div>

            @using (Html.BeginForm("Login", "Account", FormMethod.Post))
            {
                if (ViewBag.Error != null)
                {
                    <div class="alert-neon alert-danger" style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem;">
                        <i class="bi bi-exclamation-circle"></i>
                        <span>@ViewBag.Error</span>
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">Tên đăng nhập</label>
                    <div style="position: relative;">
                        <input type="text" name="username" class="form-control" placeholder="Nhập tên đăng nhập" required style="padding-left: 48px;">
                        <i class="bi bi-person" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Mật khẩu</label>
                    <div style="position: relative;">
                        <input type="password" name="password" id="password" class="form-control" placeholder="Nhập mật khẩu" required style="padding-left: 48px; padding-right: 48px;">
                        <i class="bi bi-lock" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                        <button type="button" onclick="togglePassword()" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text-muted); cursor: pointer;">
                            <i class="bi bi-eye" id="toggleIcon"></i>
                        </button>
                    </div>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: var(--text-secondary); font-size: 0.875rem;">
                        <input type="checkbox" style="accent-color: var(--neon-cyan);">
                        <span>Ghi nhớ đăng nhập</span>
                    </label>
                    <a href="#" style="color: var(--neon-cyan); font-size: 0.875rem; text-decoration: none;">
                        Quên mật khẩu?
                    </a>
                </div>

                <button type="submit" class="btn-neon" style="width: 100%; padding: 1rem; font-size: 1rem;">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Đăng nhập</span>
                </button>
            }

            <!-- Divider -->
            <div style="display: flex; align-items: center; gap: 1rem; margin: 2rem 0;">
                <div style="flex: 1; height: 1px; background: var(--color-border);"></div>
                <span style="color: var(--text-muted); font-size: 0.875rem;">hoặc</span>
                <div style="flex: 1; height: 1px; background: var(--color-border);"></div>
            </div>

            <!-- Social Login (placeholder) -->
            <div style="display: flex; gap: 1rem; margin-bottom: 2rem;">
                <button type="button" class="btn-outline-neon" style="flex: 1; padding: 0.75rem;" disabled title="Coming soon">
                    <i class="bi bi-google"></i>
                </button>
                <button type="button" class="btn-outline-neon" style="flex: 1; padding: 0.75rem;" disabled title="Coming soon">
                    <i class="bi bi-facebook"></i>
                </button>
                <button type="button" class="btn-outline-neon" style="flex: 1; padding: 0.75rem;" disabled title="Coming soon">
                    <i class="bi bi-apple"></i>
                </button>
            </div>

            <!-- Register Link -->
            <p style="text-align: center; color: var(--text-secondary);">
                Chưa có tài khoản?
                <a href="@Url.Action("Register", "Account")" style="color: var(--neon-cyan); text-decoration: none; font-weight: 600;">
                    Đăng ký ngay
                </a>
            </p>
        </div>
    </div>
</section>

@section scripts {
    <script>
        function togglePassword() {
            const password = document.getElementById('password');
            const icon = document.getElementById('toggleIcon');

            if (password.type === 'password') {
                password.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                password.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
}
