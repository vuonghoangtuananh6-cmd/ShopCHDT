@{
    var role = Session["Role"]?.ToString();
    var tenHienThi = Session["TenHienThi"] as string ?? Session["Username"]?.ToString() ?? "";
    var isLoggedIn = Session["Username"] != null;

    // Get permissions
    bool canSell = Session["Quyen_BanHang"] != null && (bool)Session["Quyen_BanHang"];
    bool canImport = Session["Quyen_NhapHang"] != null && (bool)Session["Quyen_NhapHang"];
    bool canStock = Session["Quyen_TonKho"] != null && (bool)Session["Quyen_TonKho"];
    bool canManageSupplier = canImport || canStock;

    // Get cart count
    var cart = Session["Cart"] as List<ShopQLCHDT.Models.ViewModels.CartItemViewModel> ?? new List<ShopQLCHDT.Models.ViewModels.CartItemViewModel>();
    int cartCount = cart.Sum(x => x.SoLuong);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="SmartPhone Store - Cửa hàng điện thoại chính hãng, giá tốt nhất">
    <title>@ViewBag.Title - SmartPhone Store</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />


    <link href="~/Content/neon-theme.css" rel="stylesheet" />

    @RenderSection("styles", required: false)
</head>
<body>
    <!-- Animated Background -->
    <div class="page-background"></div>

    <!-- Navigation -->
    <nav class="navbar-neon" id="mainNavbar">
        <div class="navbar-inner">
            <!-- Logo -->
            <a href="@Url.Action("Index", "Home", new { area = "" })" class="navbar-brand">
                <div class="navbar-logo">
                    <i class="bi bi-phone"></i>
                </div>
                <div class="navbar-brand-text">
                    <span class="navbar-brand-name">SmartPhone</span>
                    <span class="navbar-brand-tagline">Store</span>
                </div>
            </a>

            <!-- Navigation Links -->
            <ul class="navbar-nav">
                <li>
                    <a href="@Url.Action("Index", "Home", new { area = "" })" class="nav-link-neon @(ViewContext.RouteData.Values["controller"].ToString() == "Home" ? "active" : "")">
                        <i class="bi bi-house"></i>
                        <span>Trang chủ</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Index", "Product", new { area = "" })" class="nav-link-neon @(ViewContext.RouteData.Values["controller"].ToString() == "Product" ? "active" : "")">
                        <i class="bi bi-grid-3x3-gap"></i>
                        <span>Sản phẩm</span>
                    </a>
                </li>
                @if (role == "Nhân viên" && canSell)
                {
                    <li>
                        <a href="@Url.Action("Index", "BanHang", new { area = "NhanVien" })" class="nav-link-neon">
                            <i class="bi bi-shop"></i>
                            <span>POS</span>
                        </a>
                    </li>
                }
                @if (role == "Admin")
                {
                    <li>
                        <a href="@Url.Action("Index", "SanPham", new { area = "Admin" })" class="nav-link-neon">
                            <i class="bi bi-gear"></i>
                            <span>Quản trị</span>
                        </a>
                    </li>
                }
            </ul>

            <!-- Search Bar -->
            <div class="navbar-search">
                <form action="@Url.Action("Index", "Product")" method="get">
                    <input type="text" name="keyword" class="search-input" placeholder="Tìm kiếm điện thoại..." value="@ViewBag.Keyword">
                    <i class="bi bi-search search-icon"></i>
                </form>
            </div>

            <!-- Actions -->
            <div class="navbar-actions">
                <!-- Cart -->
                <a href="@Url.Action("Index", "Cart", new { area = "" })" class="navbar-action-btn" title="Giỏ hàng">
                    <i class="bi bi-bag"></i>
                    @if (cartCount > 0)
                    {
                        <span class="cart-badge">@cartCount</span>
                    }
                </a>

                @if (isLoggedIn)
                {
                    <!-- User Menu -->
                    <div class="user-menu">
                        <div class="user-menu-trigger">
                            <div class="user-avatar">
                                @(tenHienThi.Length > 0 ? tenHienThi[0].ToString().ToUpper() : "U")
                            </div>
                            <span class="user-name">@tenHienThi</span>
                            <i class="bi bi-chevron-down" style="font-size: 12px; color: var(--text-muted);"></i>
                        </div>

                        <div class="user-menu-dropdown">
                            @if (role == "Khách hàng")
                            {
                                <div class="user-menu-header">Tài khoản</div>
                                <a href="@Url.Action("Index", "Cart", new { area = "" })" class="user-menu-item">
                                    <i class="bi bi-receipt"></i>
                                    Đơn hàng của tôi
                                </a>
                            }

                            @if (role == "Nhân viên")
                            {
                                if (canSell)
                                {
                                    <div class="user-menu-header">Bán hàng</div>
                                    <a href="@Url.Action("Index", "BanHang", new { area = "NhanVien" })" class="user-menu-item">
                                        <i class="bi bi-shop"></i>
                                        Bán hàng (POS)
                                    </a>
                                    <a href="@Url.Action("Index", "DonHang", new { area = "NhanVien" })" class="user-menu-item">
                                        <i class="bi bi-file-earmark-text"></i>
                                        QL Đơn hàng
                                    </a>
                                }

                                if (canSell && (canImport || canStock))
                                {
                                    <div class="user-menu-divider"></div>
                                }

                                if (canImport || canStock)
                                {
                                    <div class="user-menu-header">Kho hàng</div>

                                    if (canImport)
                                    {
                                        <a href="@Url.Action("Create", "NhapHang", new { area = "Kho" })" class="user-menu-item">
                                            <i class="bi bi-box-seam"></i>
                                            Tạo phiếu nhập
                                        </a>
                                    }

                                    if (canStock)
                                    {
                                        <a href="@Url.Action("Index", "TonKho", new { area = "Kho" })" class="user-menu-item">
                                            <i class="bi bi-boxes"></i>
                                            Báo cáo tồn kho
                                        </a>
                                    }

                                    if (canManageSupplier)
                                    {
                                        <a href="@Url.Action("Index", "NhaCungCap", new { area = "Kho" })" class="user-menu-item">
                                            <i class="bi bi-truck"></i>
                                            QL Nhà cung cấp
                                        </a>
                                    }
                                }
                            }

                            @if (role == "Admin")
                            {
                                <div class="user-menu-header">Quản trị</div>
                                <a href="@Url.Action("Index", "NhanVien", new { area = "Admin" })" class="user-menu-item">
                                    <i class="bi bi-people"></i>
                                    QL Nhân viên
                                </a>
                                <a href="@Url.Action("Index", "PhanQuyen", new { area = "Admin" })" class="user-menu-item">
                                    <i class="bi bi-shield-lock"></i>
                                    Phân quyền
                                </a>
                                <a href="@Url.Action("Index", "SanPham", new { area = "Admin" })" class="user-menu-item">
                                    <i class="bi bi-phone"></i>
                                    QL Sản phẩm
                                </a>
                                <div class="user-menu-divider"></div>
                                <a href="@Url.Action("Index", "BanHang", new { area = "NhanVien" })" class="user-menu-item">
                                    <i class="bi bi-shop"></i>
                                    Vào trang POS
                                </a>
                            }

                            <div class="user-menu-divider"></div>
                            <a href="@Url.Action("Logout", "Account", new { area = "" })" class="user-menu-item danger">
                                <i class="bi bi-box-arrow-right"></i>
                                Đăng xuất
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn-neon">
                        <i class="bi bi-person"></i>
                        <span>Đăng nhập</span>
                    </a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer-neon">
        <div class="footer-container">
            <div class="footer-main">
                <!-- Brand -->
                <div class="footer-brand">
                    <a href="@Url.Action("Index", "Home")" class="footer-logo">
                        <div class="footer-logo-icon">
                            <i class="bi bi-phone"></i>
                        </div>
                        <span class="footer-logo-text">SmartPhone</span>
                    </a>
                    <p class="footer-description">
                        Mang đến những chiếc điện thoại và thiết bị công nghệ chất lượng cao với giá cả hợp lý. Cam kết chính hãng 100%.
                    </p>
                    <div class="footer-social">
                        <a href="#" class="footer-social-link" title="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="footer-social-link" title="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="#" class="footer-social-link" title="TikTok">
                            <i class="bi bi-tiktok"></i>
                        </a>
                        <a href="#" class="footer-social-link" title="YouTube">
                            <i class="bi bi-youtube"></i>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="footer-links">
                    <h4 class="footer-links-title">Sản phẩm</h4>
                    <ul class="footer-links-list">
                        <li class="footer-links-item">
                            <a href="@Url.Action("Index", "Product", new { brand = "Apple" })" class="footer-link">iPhone</a>
                        </li>
                        <li class="footer-links-item">
                            <a href="@Url.Action("Index", "Product", new { brand = "Samsung" })" class="footer-link">Samsung</a>
                        </li>
                        <li class="footer-links-item">
                            <a href="@Url.Action("Index", "Product", new { brand = "Xiaomi" })" class="footer-link">Xiaomi</a>
                        </li>
                        <li class="footer-links-item">
                            <a href="@Url.Action("Index", "Product", new { brand = "OPPO" })" class="footer-link">OPPO</a>
                        </li>
                    </ul>
                </div>

                <!-- Support -->
                <div class="footer-links">
                    <h4 class="footer-links-title">Hỗ trợ</h4>
                    <ul class="footer-links-list">
                        <li class="footer-links-item">
                            <a href="#" class="footer-link">Chính sách bảo hành</a>
                        </li>
                        <li class="footer-links-item">
                            <a href="#" class="footer-link">Đổi trả & Hoàn tiền</a>
                        </li>
                        <li class="footer-links-item">
                            <a href="#" class="footer-link">Hướng dẫn mua hàng</a>
                        </li>
                        <li class="footer-links-item">
                            <a href="#" class="footer-link">Trung tâm trợ giúp</a>
                        </li>
                    </ul>
                </div>

                <!-- Contact -->
                <div class="footer-links">
                    <h4 class="footer-links-title">Liên hệ</h4>
                    <div class="footer-contact-item">
                        <div class="footer-contact-icon">
                            <i class="bi bi-geo-alt"></i>
                        </div>
                        <div>
                            <span class="footer-contact-label">Địa chỉ</span>
                            <span class="footer-contact-value">123 Đường ABC, Quận 1, TP.HCM</span>
                        </div>
                    </div>
                    <div class="footer-contact-item">
                        <div class="footer-contact-icon">
                            <i class="bi bi-telephone"></i>
                        </div>
                        <div>
                            <span class="footer-contact-label">Hotline</span>
                            <span class="footer-contact-value">1900 1234</span>
                        </div>
                    </div>
                    <div class="footer-contact-item">
                        <div class="footer-contact-icon">
                            <i class="bi bi-envelope"></i>
                        </div>
                        <div>
                            <span class="footer-contact-label">Email</span>
                            <span class="footer-contact-value">support@smartphone.vn</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <div class="footer-bottom-content">
                    <p class="footer-copyright">
                        &copy; 2025 <a href="#">SmartPhone Store</a>. All rights reserved.
                    </p>
                    <div class="footer-social" style="gap: 1.5rem;">
                        <a href="#" class="footer-link">Điều khoản</a>
                        <a href="#" class="footer-link">Bảo mật</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', function () {
            const navbar = document.getElementById('mainNavbar');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // User menu toggle for touch devices
        document.querySelectorAll('.user-menu').forEach(function (menu) {
            menu.addEventListener('click', function (e) {
                if (window.innerWidth <= 992) {
                    this.classList.toggle('active');
                }
            });
        });

        // Close user menu when clicking outside
        document.addEventListener('click', function (e) {
            if (!e.target.closest('.user-menu')) {
                document.querySelectorAll('.user-menu').forEach(function (menu) {
                    menu.classList.remove('active');
                });
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @Scripts.Render("~/bundles/jquery")
    @RenderSection("scripts", required: false)
</body>
</html>
