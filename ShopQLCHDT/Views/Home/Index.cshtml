@model IEnumerable<ShopQLCHDT.Models.SANPHAM>
@{
    ViewBag.Title = "Trang chủ";
    var products = Model.ToList();
    var brands = products.Select(p => p.THUONGHIEU?.TENTH).Where(b => b != null).Distinct().ToList();
}

<!-- Hero Section -->
<section class="hero-section">
    <!-- Gradient Orbs -->
    <div class="hero-gradient-orb cyan"></div>
    <div class="hero-gradient-orb purple"></div>

    <div class="hero-container">
        <!-- Hero Content -->
        <div class="hero-content animate-fade-in">
            <div class="hero-badge">
                <span class="hero-badge-dot"></span>
                <span>Khuyến mãi đặc biệt</span>
            </div>

            <h1 class="hero-title">
                <span class="hero-title-line">Công nghệ</span>
                <span class="hero-title-line text-gradient">Đỉnh cao</span>
                <span class="hero-title-line">Trong tầm tay</span>
            </h1>

            <p class="hero-description">
                Khám phá bộ sưu tập điện thoại thông minh mới nhất với giá tốt nhất. Chính hãng 100%, bảo hành toàn quốc.
            </p>

            <div class="hero-actions">
                <a href="@Url.Action("Index", "Product")" class="hero-btn-primary">
                    <span>Mua ngay</span>
                    <i class="bi bi-arrow-right"></i>
                </a>
                <a href="#featured" class="hero-btn-secondary">
                    <i class="bi bi-play-circle"></i>
                    <span>Xem sản phẩm</span>
                </a>
            </div>

            <div class="hero-stats">
                <div class="hero-stat">
                    <div class="hero-stat-value">500+</div>
                    <div class="hero-stat-label">Sản phẩm</div>
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-value">10K+</div>
                    <div class="hero-stat-label">Khách hàng</div>
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-value">99%</div>
                    <div class="hero-stat-label">Hài lòng</div>
                </div>
            </div>
        </div>

        <!-- Hero Visual -->
        <div class="hero-visual">
            <div class="hero-phone-showcase">
                <div class="hero-glow-ring"></div>
                <div class="hero-glow-ring"></div>
                <div class="hero-glow-ring"></div>

                <div class="hero-phone-main">
                    <img src="~/Content/Images/@products.First().HINHANH" alt="Featured Phone">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Brands Section -->
<section class="brands-section">
    <div class="neon-container">
        <p class="brands-title">Thương hiệu hàng đầu</p>
        <div class="brands-grid">
            <a href="@Url.Action("Index", "Product", new { brand = 1 })" class="brand-item">
                <span class="brand-name">Apple</span>
            </a>
            <a href="@Url.Action("Index", "Product", new { brand = 2 })" class="brand-item">
                <span class="brand-name">Samsung</span>
            </a>
            <a href="@Url.Action("Index", "Product", new { brand = 3 })" class="brand-item">
                <span class="brand-name">Xiaomi</span>
            </a>
            <a href="@Url.Action("Index", "Product", new { brand = 4 })" class="brand-item">
                <span class="brand-name">OPPO</span>
            </a>
            <a href="@Url.Action("Index", "Product", new { brand = 5 })" class="brand-item">
                <span class="brand-name">Vivo</span>
            </a>
            <a href="@Url.Action("Index", "Product", new { brand = 6 })" class="brand-item">
                <span class="brand-name">Realme</span>
            </a>
        </div>
    </div>
</section>

<!-- Featured Products Section -->
<section class="section" id="featured">
    <div class="neon-container">
        <div class="section-header">
            <div>
                <h2 class="section-title">Sản phẩm nổi bật</h2>
                <p class="section-subtitle" style="color: var(--text-secondary); margin-top: 12px;">
                    Những điện thoại được yêu thích nhất
                </p>
            </div>
            <a href="@Url.Action("Index", "Product")" class="btn-outline-neon">
                Xem tất cả
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="products-grid">
            @if (products.Any())
            {
                int index = 0;
                foreach (var item in products.Take(8))
                {
                    index++;
                    <a href="@Url.Action("Details", "Product", new { id = item.MASP })" class="product-card animate-slide-up" style="animation-delay: @(index * 0.1)s;">
                        <div class="product-card-image">
                            @if (index <= 2)
                            {
                                <div class="product-card-badges">
                                    <span class="badge-neon badge-new">Mới</span>
                                </div>
                            }
                            <div class="product-card-actions">
                                <button class="product-card-action-btn" title="Yêu thích" onclick="event.preventDefault();">
                                    <i class="bi bi-heart"></i>
                                </button>
                                <button class="product-card-action-btn" title="So sánh" onclick="event.preventDefault();">
                                    <i class="bi bi-shuffle"></i>
                                </button>
                            </div>
                            <img src="~/Content/Images/@item.HINHANH" alt="@item.TENSP">
                        </div>
                        <div class="product-card-body">
                            @if (item.THUONGHIEU != null)
                            {
                                <div class="product-card-brand">@item.THUONGHIEU.TENTH</div>
                            }
                            <h3 class="product-card-title">@item.TENSP</h3>
                            <div class="product-card-footer">
                                <div class="product-card-price">
                                    <span class="price-current">@item.GIABAN.Value.ToString("N0")</span>
                                    <span class="price-currency">đ</span>
                                </div>
                                <button class="btn-neon" onclick="event.preventDefault(); addToCart(@item.MASP);" style="padding: 8px 16px; font-size: 12px;">
                                    <i class="bi bi-bag-plus"></i>
                                </button>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="glass-card" style="grid-column: span 4; text-align: center; padding: 3rem;">
                    <i class="bi bi-inbox" style="font-size: 3rem; color: var(--text-muted);"></i>
                    <p style="color: var(--text-secondary); margin-top: 1rem;">Chưa có sản phẩm nào</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- Promo Banner -->
<section class="section" style="padding-top: 0;">
    <div class="neon-container">
        <div class="glass-card" style="padding: 3rem; position: relative; overflow: hidden; background: linear-gradient(135deg, rgba(168, 85, 247, 0.15) 0%, rgba(236, 72, 153, 0.15) 100%); border-color: rgba(168, 85, 247, 0.3);">
            <div style="position: absolute; top: -50%; right: -20%; width: 60%; aspect-ratio: 1; background: radial-gradient(circle, rgba(168, 85, 247, 0.2) 0%, transparent 70%); pointer-events: none;"></div>
            <div style="position: relative; z-index: 1; max-width: 600px;">
                <span style="display: inline-block; padding: 0.5rem 1rem; background: linear-gradient(135deg, #a855f7, #ec4899); border-radius: 9999px; font-size: 0.875rem; font-weight: 600; color: white; margin-bottom: 1rem;">
                    Ưu đãi đặc biệt
                </span>
                <h2 style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem;">
                    Giảm đến <span style="color: #f472b6;">30%</span> cho iPhone 15 Series
                </h2>
                <p style="color: var(--text-secondary); font-size: 1.125rem; margin-bottom: 1.5rem;">
                    Ưu đãi có hạn! Nhanh tay sở hữu iPhone 15 với giá tốt nhất thị trường. Tặng kèm phụ kiện chính hãng.
                </p>
                <a href="@Url.Action("Index", "Product", new { brand = 1 })" class="hero-btn-primary" style="background: linear-gradient(135deg, #a855f7, #ec4899);">
                    <span>Mua ngay</span>
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="section">
    <div class="neon-container">
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;">
            <div class="glass-card" style="text-align: center; padding: 2rem;">
                <div style="width: 60px; height: 60px; margin: 0 auto 1rem; background: rgba(0, 245, 255, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-truck" style="font-size: 1.5rem; color: var(--neon-cyan);"></i>
                </div>
                <h4 style="font-family: var(--font-display); font-weight: 600; margin-bottom: 0.5rem;">Giao hàng nhanh</h4>
                <p style="color: var(--text-muted); font-size: 0.875rem;">Miễn phí ship toàn quốc</p>
            </div>

            <div class="glass-card" style="text-align: center; padding: 2rem;">
                <div style="width: 60px; height: 60px; margin: 0 auto 1rem; background: rgba(34, 197, 94, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-shield-check" style="font-size: 1.5rem; color: var(--neon-green);"></i>
                </div>
                <h4 style="font-family: var(--font-display); font-weight: 600; margin-bottom: 0.5rem;">Chính hãng 100%</h4>
                <p style="color: var(--text-muted); font-size: 0.875rem;">Cam kết hàng chính hãng</p>
            </div>

            <div class="glass-card" style="text-align: center; padding: 2rem;">
                <div style="width: 60px; height: 60px; margin: 0 auto 1rem; background: rgba(249, 115, 22, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-repeat" style="font-size: 1.5rem; color: var(--neon-orange);"></i>
                </div>
                <h4 style="font-family: var(--font-display); font-weight: 600; margin-bottom: 0.5rem;">Đổi trả dễ dàng</h4>
                <p style="color: var(--text-muted); font-size: 0.875rem;">30 ngày đổi trả miễn phí</p>
            </div>

            <div class="glass-card" style="text-align: center; padding: 2rem;">
                <div style="width: 60px; height: 60px; margin: 0 auto 1rem; background: rgba(168, 85, 247, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-headset" style="font-size: 1.5rem; color: var(--neon-purple);"></i>
                </div>
                <h4 style="font-family: var(--font-display); font-weight: 600; margin-bottom: 0.5rem;">Hỗ trợ 24/7</h4>
                <p style="color: var(--text-muted); font-size: 0.875rem;">Tư vấn nhiệt tình</p>
            </div>
        </div>
    </div>
</section>

@section scripts {
    <script>
        function addToCart(productId) {
            fetch('@Url.Action("AddToCart", "Cart")/' + productId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Update cart badge
                    const badge = document.querySelector('.cart-badge');
                    if (badge) {
                        badge.textContent = data.cartCount;
                    } else {
                        const cartBtn = document.querySelector('.navbar-action-btn[title="Giỏ hàng"]');
                        if (cartBtn) {
                            const newBadge = document.createElement('span');
                            newBadge.className = 'cart-badge';
                            newBadge.textContent = data.cartCount;
                            cartBtn.appendChild(newBadge);
                        }
                    }
                    // Show toast notification
                    showToast('Đã thêm vào giỏ hàng!', 'success');
                } else {
                    showToast(data.message || 'Có lỗi xảy ra', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Có lỗi xảy ra', 'error');
            });
        }

        function showToast(message, type) {
            // Create toast element
            const toast = document.createElement('div');
            toast.style.cssText = `
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                padding: 1rem 1.5rem;
                background: ${type === 'success' ? 'rgba(34, 197, 94, 0.9)' : 'rgba(239, 68, 68, 0.9)'};
                color: white;
                border-radius: 12px;
                font-weight: 500;
                z-index: 9999;
                animation: slideIn 0.3s ease-out;
                backdrop-filter: blur(10px);
            `;
            toast.textContent = message;

            // Add animation keyframes
            if (!document.querySelector('#toast-styles')) {
                const style = document.createElement('style');
                style.id = 'toast-styles';
                style.textContent = `
                    @@keyframes slideIn {
                        from { transform: translateX(100%); opacity: 0; }
                        to { transform: translateX(0); opacity: 1; }
                    }
                    @@keyframes slideOut {
                        from { transform: translateX(0); opacity: 1; }
                        to { transform: translateX(100%); opacity: 0; }
                    }
                `;
                document.head.appendChild(style);
            }

            document.body.appendChild(toast);

            // Remove after 3 seconds
            setTimeout(() => {
                toast.style.animation = 'slideOut 0.3s ease-out forwards';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
}

@section styles {
    <style>
        @@media (max-width: 1000px) {
            .section > .neon-container > div[style*="grid-template-columns: repeat(4"] {
                grid-template-columns: repeat(2, 1fr) !important;
            }
        }

        @@media (max-width: 600px) {
            .section > .neon-container > div[style*="grid-template-columns: repeat(4"] {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
}
