@model ShopQLCHDT.Models.PHANQUYEN

@{
    ViewBag.Title = "Bán hàng tại quầy (POS)";
    Layout = "~/Areas/NhanVien/Views/Shared/_LayoutPOS.cshtml"; // <--- THÊM DÒNG NÀY
}



<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-uppercase">Cập nhật quyền hạn</h2>
            <p class="text-muted mt-1">Nhân viên: <span class="text-primary fw-bold fs-5">@ViewBag.TenNV</span></p>
        </div>
        <a href="@Url.Action("Index", "PhanQuyen")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    @using (Html.BeginForm("Edit", "PhanQuyen", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.MANV)
        @Html.HiddenFor(model => model.ID)

        @helper RenderPermissionCard(string label, string desc, string name, bool? value, string icon)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card p-3 mb-3 permission-card h-100 shadow-sm"
                     onclick="document.getElementById('@name').click()">

                    <div class="d-flex justify-content-between align-items-center h-100">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-light rounded p-3 text-primary">
                                <i class="@icon fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">@label</h6>
                                <small class="text-muted">@desc</small>
                            </div>
                        </div>

                        <div class="form-check form-switch m-0" onclick="event.stopPropagation()">
                            @* QUAN TRỌNG: Dùng Html.CheckBox để tạo nút gạt thật sự *@
                            @* GetValueOrDefault(): Nếu null thì coi là false (tắt) *@
                            @Html.CheckBox(name, value.GetValueOrDefault(), new { @class = "form-check-input", @id = name })
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row">
            <div class="col-12"><h5 class="text-uppercase text-secondary fw-bold my-3 border-bottom pb-2">Nghiệp vụ Bán hàng</h5></div>

            @RenderPermissionCard("QL Đơn hàng", "Xử lý đơn, in bill", "QL_DONHANG", Model.QL_DONHANG, "bi bi-receipt")
            @RenderPermissionCard("QL Khách hàng", "Tra cứu lịch sử mua", "QL_KHACHHANG", Model.QL_KHACHHANG, "bi bi-people")

            <div class="col-12"><h5 class="text-uppercase text-secondary fw-bold my-3 border-bottom pb-2 mt-4">Kho </h5></div>

            @RenderPermissionCard("QL Nhập hàng", "Tạo phiếu nhập kho", "QL_NHAPHANG", Model.QL_NHAPHANG, "bi bi-box-arrow-in-down")
            @RenderPermissionCard("Xem Tồn kho", "Kiểm kê số lượng", "QL_BPKHO", Model.QL_BPKHO, "bi bi-boxes")
            @RenderPermissionCard("Nhà cung cấp", "Quản lý đối tác", "QL_NHACC", Model.QL_NHACC, "bi bi-truck")
            <div class="col-12"><h5 class="text-uppercase text-secondary fw-bold my-3 border-bottom pb-2 mt-4"> Hệ thống</h5></div>
            @RenderPermissionCard("QL Nhân viên", "Tạo tài khoản, lương", "QL_NHANVIEN", Model.QL_NHANVIEN, "bi bi-person-badge")
            @RenderPermissionCard("Xem Thống kê", "Doanh thu, báo cáo", "THONGKE", Model.THONGKE, "bi bi-graph-up-arrow")
            @RenderPermissionCard("QL Sản phẩm", "Thêm, sửa, giá bán", "QL_SANPHAM", Model.QL_SANPHAM, "bi bi-phone")
        </div>

        <div class="mt-4 pt-3 d-flex justify-content-end gap-2 fixed-bottom bg-white p-3 shadow border-top" style="position: sticky; bottom: 0; z-index: 100;">
            <a href="@Url.Action("Index")" class="btn btn-light border px-4">Hủy</a>
            <button type="submit" class="btn btn-primary px-5 fw-bold"><i class="bi bi-save"></i> LƯU CẬP NHẬT</button>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Script đổi màu card khi switch được bật
            $('.form-check-input').on('change', function () {
                if (this.checked) {
                    $(this).closest('.permission-card').addClass('active-card');
                } else {
                    $(this).closest('.permission-card').removeClass('active-card');
                }
            });

            // Chạy lần đầu khi load trang
            $('.form-check-input').trigger('change');
        });
    </script>
}
