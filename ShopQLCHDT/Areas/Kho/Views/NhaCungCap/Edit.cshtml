@model ShopQLCHDT.Models.NHACUNGCAP

@{
    ViewBag.Title = "Chỉnh sửa Nhà Cung Cấp";
}

<div class="section pt-5">
    <div class="neon-container">

        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">

                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h2 class="section-title text-gradient m-0">Cập nhật thông tin</h2>
                    <a href="@Url.Action("Index")" class="btn-outline-neon btn-sm border-0 text-secondary">
                        <i class="bi bi-arrow-left me-2"></i> Quay lại
                    </a>
                </div>

                <div class="glass-card animate-slide-up p-5">

                    <div class="text-center mb-5">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3 shadow-glow-purple"
                             style="width: 80px; height: 80px; background: rgba(168, 85, 247, 0.1); border: 1px solid rgba(168, 85, 247, 0.3);">
                            <span class="fs-1 fw-bold text-white">@(Model.TENNCC?.Substring(0,1) ?? "N")</span>
                        </div>
                        <h4 class="text-white">@Model.TENNCC</h4>
                        <p class="text-muted text-sm">Mã NCC: #@Model.MANCC</p>
                    </div>

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.MANCC)

                        @Html.ValidationSummary(true, "", new { @class = "alert alert-neon alert-danger mb-4" })

                        <div class="form-group mb-4">
                            @Html.LabelFor(model => model.TENNCC, "Tên Nhà Cung Cấp", new { @class = "form-label text-xs text-uppercase letter-spacing-1" })
                            <div class="position-relative">
                                <span class="position-absolute top-50 start-0 translate-middle-y ms-3 text-muted">
                                    <i class="bi bi-shop"></i>
                                </span>
                                @Html.EditorFor(model => model.TENNCC, new { htmlAttributes = new { @class = "form-control ps-5", placeholder = "Nhập tên nhà cung cấp..." } })
                            </div>
                            @Html.ValidationMessageFor(model => model.TENNCC, "", new { @class = "text-danger text-xs mt-1" })
                        </div>

                        <div class="form-group mb-4">
                            @Html.LabelFor(model => model.DIACHI, "Địa chỉ", new { @class = "form-label text-xs text-uppercase letter-spacing-1" })
                            <div class="position-relative">
                                <span class="position-absolute top-50 start-0 translate-middle-y ms-3 text-muted">
                                    <i class="bi bi-geo-alt"></i>
                                </span>
                                @Html.EditorFor(model => model.DIACHI, new { htmlAttributes = new { @class = "form-control ps-5", placeholder = "Nhập địa chỉ..." } })
                            </div>
                            @Html.ValidationMessageFor(model => model.DIACHI, "", new { @class = "text-danger text-xs mt-1" })
                        </div>

                        <div class="form-group mb-5">
                            @Html.LabelFor(model => model.DIENTHOAI, "Số điện thoại", new { @class = "form-label text-xs text-uppercase letter-spacing-1" })
                            <div class="position-relative">
                                <span class="position-absolute top-50 start-0 translate-middle-y ms-3 text-muted">
                                    <i class="bi bi-telephone"></i>
                                </span>
                                @Html.EditorFor(model => model.DIENTHOAI, new { htmlAttributes = new { @class = "form-control ps-5 font-monospace", placeholder = "Nhập số điện thoại..." } })
                            </div>
                            @Html.ValidationMessageFor(model => model.DIENTHOAI, "", new { @class = "text-danger text-xs mt-1" })
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn-neon w-100 py-3 shadow-glow-cyan fs-6">
                                <i class="bi bi-save me-2"></i> Lưu Thay Đổi
                            </button>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>