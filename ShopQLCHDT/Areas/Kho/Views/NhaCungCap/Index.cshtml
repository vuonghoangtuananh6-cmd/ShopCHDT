@model IEnumerable<ShopQLCHDT.Models.NHACUNGCAP>

@{
    ViewBag.Title = "Quản lý Nhà Cung Cấp";
}

<div class="section pt-4">
    <div class="neon-container">

        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-5 gap-3">
            <div>
                <h2 class="section-title text-gradient m-0">Nhà Cung Cấp</h2>
                <p class="text-secondary mt-1 mb-0">Quản lý danh sách đối tác cung ứng hàng hóa.</p>
            </div>

            <a href="@Url.Action("Create")" class="btn-neon shadow-glow-cyan">
                <i class="bi bi-plus-lg me-2"></i> Thêm Nhà Cung Cấp
            </a>
        </div>

        <div class="glass-card animate-slide-up p-0 overflow-hidden">
            <div class="table-responsive custom-scrollbar">
                <table class="table pos-table align-middle mb-0 table-hover-neon">
                    <thead>
                        <tr>
                            <th class="ps-4 py-3 text-secondary text-uppercase text-xs letter-spacing-1">Tên Nhà Cung Cấp</th>
                            <th class="py-3 text-secondary text-uppercase text-xs letter-spacing-1">Địa chỉ</th>
                            <th class="py-3 text-secondary text-uppercase text-xs letter-spacing-1">Điện thoại</th>
                            <th class="text-end pe-4 py-3 text-secondary text-uppercase text-xs letter-spacing-1">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr class="transition-base">
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="d-flex align-items-center justify-content-center rounded-circle border border-secondary shadow-sm"
                                                 style="width: 40px; height: 40px; background: rgba(236, 72, 153, 0.1); color: var(--neon-pink); font-weight: bold; font-size: 16px;">
                                                @(item.TENNCC?.Substring(0, 1) ?? "N")
                                            </div>
                                            <div>
                                                <div class="fw-bold text-white fs-6">@item.TENNCC</div>
                                                <div class="text-muted text-xs">Mã: #@item.MANCC</div>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="d-flex align-items-start gap-2 text-secondary" style="max-width: 300px;">
                                            <i class="bi bi-geo-alt mt-1 flex-shrink-0"></i>
                                            <span class="text-sm">@(item.DIACHI ?? "Chưa cập nhật")</span>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-telephone text-muted"></i>
                                            <span class="text-neon-cyan font-monospace fw-bold">@(item.DIENTHOAI ?? "---")</span>
                                        </div>
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a href="@Url.Action("Edit", new { id = item.MANCC })"
                                               class="btn btn-sm btn-outline-warning border-0 bg-opacity-10"
                                               style="background: rgba(251, 191, 36, 0.1);"
                                               title="Sửa thông tin">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a href="@Url.Action("Details", new { id = item.MANCC })"
                                               class="btn btn-sm btn-outline-info border-0 bg-opacity-10"
                                               style="background: rgba(6, 182, 212, 0.1);"
                                               title="Xem chi tiết">
                                                <i class="bi bi-info-circle"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", new { id = item.MANCC })"
                                               class="btn btn-sm btn-outline-danger border-0 bg-opacity-10"
                                               style="background: rgba(239, 68, 68, 0.1);"
                                               title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="d-flex flex-column align-items-center text-muted">
                                        <i class="bi bi-shop-window fs-1 mb-2 opacity-50"></i>
                                        <p class="m-0">Chưa có nhà cung cấp nào.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="px-4 py-3 border-top border-secondary d-flex justify-content-between align-items-center bg-dark bg-opacity-25">
                <span class="text-secondary text-xs text-uppercase fw-bold">
                    Tổng số: <span class="text-white">@Model.Count()</span> đối tác
                </span>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table-hover-neon tbody tr:hover {
            background-color: rgba(255, 255, 255, 0.03) !important;
        }
        /* Style riêng cho các nút hành động icon */
        .btn-outline-warning:hover {
            background: var(--neon-yellow) !important;
            color: #000 !important;
            box-shadow: 0 0 10px rgba(251, 191, 36, 0.5);
        }

        .btn-outline-info:hover {
            background: var(--neon-cyan) !important;
            color: #000 !important;
            box-shadow: 0 0 10px rgba(6, 182, 212, 0.5);
        }

        .btn-outline-danger:hover {
            background: #ef4444 !important;
            color: #fff !important;
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.5);
        }
    </style>
}