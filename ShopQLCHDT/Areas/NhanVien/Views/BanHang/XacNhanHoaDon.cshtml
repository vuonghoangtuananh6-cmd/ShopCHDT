@model ShopQLCHDT.Areas.NhanVien.Controllers.ConfirmOrderViewModel
@{
    ViewBag.Title = "Xác nhận Hóa đơn";
    decimal tongTien = Model.ChiTietDonHang != null ? Model.ChiTietDonHang.Sum(item => item.DonGia * item.SoLuong) : 0;
}

<div class="section pt-4">
    <div class="neon-container">

        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="section-title text-gradient m-0">Xác Nhận Đơn Hàng</h2>
                <p class="text-secondary mt-1 mb-0">Rà soát thông tin trước khi lưu vào hệ thống.</p>
            </div>

            <a href="javascript:window.history.back();" class="btn-outline-neon">
                <i class="bi bi-arrow-left me-2"></i> Quay lại POS
            </a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-neon alert-danger mb-4 animate-fade-in">
                <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
            </div>
        }

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="d-flex flex-column gap-4 h-100">

                    <div class="glass-card animate-slide-up">
                        <h4 class="text-white mb-4 pb-2 border-bottom border-secondary d-flex align-items-center">
                            <span class="badge-neon me-2"><i class="bi bi-person-vcard"></i></span>
                            Khách hàng
                        </h4>

                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center gap-3 p-2 rounded hover-bg-light">
                                <div class="text-secondary fs-4"><i class="bi bi-person-circle"></i></div>
                                <div class="d-flex align-items-baseline flex-wrap">
                                    <span class="text-muted text-xs text-uppercase fw-bold me-2 text-nowrap">Họ tên:</span>
                                    <span class="text-white fw-bold fs-5">@Model.KhachHang.TENKH</span>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3 p-2 rounded hover-bg-light">
                                <div class="text-secondary fs-4"><i class="bi bi-telephone"></i></div>
                                <div class="d-flex align-items-baseline flex-wrap">
                                    <span class="text-muted text-xs text-uppercase fw-bold me-2 text-nowrap">SĐT:</span>
                                    <span class="text-neon-cyan font-monospace fs-5">@Model.KhachHang.DIENTHOAI</span>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3 p-2 rounded hover-bg-light">
                                <div class="text-secondary fs-4"><i class="bi bi-geo-alt"></i></div>
                                <div class="d-flex align-items-baseline flex-wrap">
                                    <span class="text-muted text-xs text-uppercase fw-bold me-2 text-nowrap">Địa chỉ:</span>
                                    <span class="text-white">@(string.IsNullOrEmpty(Model.KhachHang.DIACHI) ? "Tại quầy" : Model.KhachHang.DIACHI)</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card animate-slide-up flex-grow-1" style="animation-delay: 0.1s">
                        <h4 class="text-white mb-4 pb-2 border-bottom border-secondary d-flex align-items-center">
                            <span class="badge-neon badge-sale me-2"><i class="bi bi-info-circle"></i></span>
                            Thông tin đơn
                        </h4>

                        <div class="d-flex align-items-center mb-3">
                            <span class="text-muted text-xs text-uppercase fw-bold me-2 text-nowrap" style="min-width: 80px;">Nhân viên:</span>
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-person-badge text-accent"></i>
                                <span class="text-white fw-bold">@Model.TenNV</span>
                            </div>
                        </div>

                        <div class="d-flex align-items-start">
                            <span class="text-muted text-xs text-uppercase fw-bold me-2 text-nowrap" style="min-width: 80px; margin-top: 4px;">Ghi chú:</span>
                            <div class="flex-grow-1 p-2 rounded" style="background: rgba(0,0,0,0.3); border: 1px dashed var(--color-border);">
                                @if (!string.IsNullOrEmpty(Model.GhiChu))
                                {
                                    <span class="text-white fst-italic">@Model.GhiChu</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Không có ghi chú.</span>
                                }
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="col-lg-8">
                <div class="glass-card h-100 animate-slide-up" style="animation-delay: 0.2s;">
                    <h4 class="text-white mb-3 pb-2 border-bottom border-secondary d-flex align-items-center">
                        <span class="badge-neon badge-new me-2"><i class="bi bi-cart-check"></i></span>
                        Chi tiết sản phẩm
                    </h4>

                    <div class="table-responsive custom-scrollbar mb-4" style="max-height: 400px;">
                        <table class="table pos-table align-middle mb-0">
                            <thead class="sticky-top" style="background: rgba(10,10,15,0.95); backdrop-filter: blur(5px);">
                                <tr>
                                    <th class="ps-3" style="width: 45%">Sản phẩm</th>
                                    <th class="text-center" style="width: 15%">SL</th>
                                    <th class="text-end" style="width: 20%">Đơn giá</th>
                                    <th class="text-end pe-3" style="width: 20%">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ChiTietDonHang != null && Model.ChiTietDonHang.Any())
                                {
                                    foreach (var item in Model.ChiTietDonHang)
                                    {
                                        <tr>
                                            <td class="ps-3">
                                                <div class="fw-bold text-white">@(item.TenSP ?? "Sản phẩm #" + item.MaSP)</div>
                                                <div class="text-muted text-xs font-monospace">MSP: @item.MaSP</div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge-neon badge-new px-3">x @item.SoLuong</span>
                                            </td>
                                            <td class="text-end text-secondary font-monospace">
                                                @item.DonGia.ToString("N0")
                                            </td>
                                            <td class="text-end pe-3 fw-bold text-accent font-monospace">
                                                @((item.DonGia * item.SoLuong).ToString("N0"))
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-4">Giỏ hàng trống</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-auto border-top border-secondary pt-4">
                        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                            <span class="text-secondary text-uppercase fw-bold letter-spacing-1">Tổng thanh toán:</span>
                            <div class="text-end">
                                <div class="text-gradient fs-1 fw-bold font-display">
                                    @tongTien.ToString("N0") <span class="fs-4 text-muted">VNĐ</span>
                                </div>
                            </div>
                        </div>

                        @using (Html.BeginForm("LuuHoaDon", "BanHang", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()

                            if (tongTien > 0)
                            {
                                <button type="submit" class="btn-neon w-100 py-3 fs-5 shadow-glow-cyan text-uppercase fw-bold transition-transform">
                                    <i class="bi bi-printer-fill me-2"></i> Lưu & Xuất Hóa Đơn
                                </button>
                            }
                            else
                            {
                                <div class="alert alert-warning text-center m-0">
                                    <i class="bi bi-exclamation-triangle"></i> Đơn hàng có giá trị 0đ.
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>