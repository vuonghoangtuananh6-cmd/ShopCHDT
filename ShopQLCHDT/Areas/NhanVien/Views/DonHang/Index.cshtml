@model IEnumerable<ShopQLCHDT.Models.HOADON>

@{
    ViewBag.Title = "Lịch sử Đơn hàng";
    string currentTrangThai = ViewBag.TrangThai ?? "";
}

<div class="section pt-4">
    <div class="neon-container">

        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-5 gap-3">
            <div>
                <h2 class="section-title text-gradient m-0">Quản lý Đơn hàng</h2>
                <p class="text-secondary mt-1 mb-0">Theo dõi và quản lý lịch sử giao dịch.</p>
            </div>

            <div class="glass-card p-2 d-inline-flex align-items-center" style="border-radius: var(--radius-full);">
                @using (Html.BeginForm("Index", "DonHang", FormMethod.Get, new { @class = "d-flex align-items-center m-0" }))
                {
                    <label class="text-secondary text-sm fw-bold text-uppercase px-3 text-nowrap">
                        <i class="bi bi-funnel-fill me-1"></i> Trạng thái:
                    </label>
                    <div style="min-width: 150px;">
                        <select name="trangThai" class="form-control form-control-sm border-0 bg-transparent text-white py-1"
                                style="box-shadow: none;" onchange="this.form.submit()">
                            <option value="" class="text-dark" @(currentTrangThai == "" ? "selected" : "")>Tất cả đơn hàng</option>
                            <option value="Chờ duyệt" class="text-dark" @(currentTrangThai == "Chờ duyệt" ? "selected" : "")>⏳ Chờ duyệt</option>
                            <option value="Đã duyệt" class="text-dark" @(currentTrangThai == "Đã duyệt" ? "selected" : "")>✅ Đã duyệt</option>
                        </select>
                    </div>
                }
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-neon alert-success mb-4 animate-fade-in d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                @TempData["Success"]
            </div>
        }

        <div class="glass-card animate-slide-up p-0 overflow-hidden">
            <div class="table-responsive custom-scrollbar">
                <table class="table pos-table align-middle mb-0 table-hover-neon">
                    <thead>
                        <tr>
                            <th class="ps-4 py-3 text-secondary text-uppercase text-xs letter-spacing-1">Mã HĐ</th>
                            <th class="py-3 text-secondary text-uppercase text-xs letter-spacing-1">Khách hàng</th>
                            <th class="py-3 text-secondary text-uppercase text-xs letter-spacing-1">Nhân viên</th>
                            <th class="py-3 text-secondary text-uppercase text-xs letter-spacing-1">Ngày bán</th>
                            <th class="text-end py-3 text-secondary text-uppercase text-xs letter-spacing-1">Tổng tiền</th>
                            <th class="text-center py-3 text-secondary text-uppercase text-xs letter-spacing-1">Trạng thái</th>
                            <th class="text-end pe-4 py-3"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr class="transition-base">
                                    <td class="ps-4">
                                        <div class="fw-bold text-white font-monospace">#@item.MAHD</div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="user-avatar" style="width: 28px; height: 28px; font-size: 10px;">
                                                @(item.KHACHHANG?.TENKH?.Substring(0,1) ?? "?")
                                            </div>
                                            <span class="text-white fw-medium">@(item.KHACHHANG?.TENKH ?? "Khách vãng lai")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-muted text-sm">
                                            <i class="bi bi-person-badge me-1"></i> @(item.NHANVIEN?.TENNV ?? "---")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-secondary font-monospace text-sm">
                                            @(item.NGAYBAN.HasValue ? item.NGAYBAN.Value.ToString("dd/MM/yyyy HH:mm") : "---")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <span class="text-accent fw-bold font-monospace">
                                            @((item.TONGTIEN ?? 0).ToString("N0"))
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @if (item.TRANGTHAI == "Chờ duyệt")
                                        {
                                            <span class="badge-neon" style="background: rgba(251, 191, 36, 0.1); color: var(--neon-yellow); border: 1px solid rgba(251, 191, 36, 0.3);">
                                                <i class="bi bi-hourglass-split me-1"></i> Chờ duyệt
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-neon badge-new">
                                                <i class="bi bi-check2-all me-1"></i> Đã duyệt
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="@Url.Action("Details", new { id = item.MAHD })"
                                           class="btn-outline-neon btn-sm py-1 px-3 border-0"
                                           style="background: rgba(255,255,255,0.05);"
                                           title="Xem chi tiết">
                                            Chi tiết <i class="bi bi-chevron-right ms-1" style="font-size: 10px;"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="d-flex flex-column align-items-center text-muted">
                                        <i class="bi bi-inbox fs-1 mb-2 opacity-50"></i>
                                        <p class="m-0">Chưa có đơn hàng nào.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="px-4 py-3 border-top border-secondary d-flex justify-content-between align-items-center">
                <span class="text-secondary text-xs text-uppercase fw-bold">
                    Tổng số: <span class="text-white">@Model.Count()</span> đơn hàng
                </span>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* CSS riêng bổ sung cho hiệu ứng hover hàng */
        .table-hover-neon tbody tr:hover {
            background-color: rgba(255, 255, 255, 0.03) !important;
            transform: scale(1); /* Reset transform để tránh lỗi render text */
        }

            .table-hover-neon tbody tr:hover td {
                color: white; /* Giữ màu chữ trắng sáng khi hover */
            }

            .table-hover-neon tbody tr:hover .text-muted {
                color: var(--text-secondary) !important;
            }
    </style>
}