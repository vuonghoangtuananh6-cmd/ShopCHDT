@{
    var role = Session["Role"]?.ToString();
    var tenHienThi = Session["TenHienThi"] as string ?? Session["Username"]?.ToString() ?? "";
    var isLoggedIn = Session["Username"] != null;

    // Get permissions
    bool canSell = Session["Quyen_BanHang"] != null && (bool)Session["Quyen_BanHang"];
    bool canImport = Session["Quyen_NhapHang"] != null && (bool)Session["Quyen_NhapHang"];
    bool canStock = Session["Quyen_TonKho"] != null && (bool)Session["Quyen_TonKho"];
    bool canManageSupplier = canImport || canStock;

    // Get cart count
    var cart = Session["Cart"] as List<ShopQLCHDT.Models.ViewModels.CartItemViewModel> ?? new List<ShopQLCHDT.Models.ViewModels.CartItemViewModel>();
    int cartCount = cart.Sum(x => x.SoLuong);
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Điện Máy SmartHome</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/Content/style.css" />
    <link rel="stylesheet" href="~/Content/neon-theme.css" />
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>


<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top navbar-custom">
        <div class="container">

            <a href="@Url.Action("Index", "Home", new { area = "" })" class="navbar-brand">
                <div class="navbar-logo">
                    <i class="bi bi-phone"></i>
                </div>
                <div class="navbar-brand-text">
                    <span class="navbar-brand-name">SmartPhone</span>
                    <span class="navbar-brand-tagline">Store</span>
                </div>
            </a>

            <div class="collapse navbar-collapse" id="navbarMain">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        @Html.ActionLink("Trang chủ", "Index", "Home", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Sản phẩm", "Index", "Product", new { area = "" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Tồn kho", "Index", "TonKho", new { area = "Kho" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Nhập hàng", "Index", "NhapHang", new { area = "Kho" }, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Nhà Cung Cấp", "Index", "NhaCungCap", new { area = "Kho" }, new { @class = "nav-link" })
                    </li>
                </ul>
                <div class="navbar-actions">
                    <!-- Cart -->
                    <a href="@Url.Action("Index", "Cart", new { area = "" })" class="navbar-action-btn" title="Giỏ hàng">
                        <i class="bi bi-bag"></i>
                        @if (cartCount > 0)
                        {
                            <span class="cart-badge">@cartCount</span>
                        }
                    </a>

                    @if (isLoggedIn)
                    {
                        <!-- User Menu -->
                        <div class="user-menu">
                            <div class="user-menu-trigger">
                                <div class="user-avatar">
                                    @(tenHienThi.Length > 0 ? tenHienThi[0].ToString().ToUpper() : "U")
                                </div>
                                <span class="user-name">@tenHienThi</span>
                                <i class="bi bi-chevron-down" style="font-size: 12px; color: var(--text-muted);"></i>
                            </div>

                            <div class="user-menu-dropdown">
                                @if (role == "Khách hàng")
                                {
                                    <div class="user-menu-header">Tài khoản</div>
                                    <a href="@Url.Action("Index", "Cart", new { area = "" })" class="user-menu-item">
                                        <i class="bi bi-receipt"></i>
                                        Đơn hàng của tôi
                                    </a>
                                }

                                @if (role == "Nhân viên")
                                {
                                    if (canSell)
                                    {
                                        <div class="user-menu-header">Bán hàng</div>
                                        <a href="@Url.Action("Index", "BanHang", new { area = "NhanVien" })" class="user-menu-item">
                                            <i class="bi bi-shop"></i>
                                            Bán hàng (POS)
                                        </a>
                                        <a href="@Url.Action("Index", "DonHang", new { area = "NhanVien" })" class="user-menu-item">
                                            <i class="bi bi-file-earmark-text"></i>
                                            QL Đơn hàng
                                        </a>
                                    }

                                    if (canSell && (canImport || canStock))
                                    {
                                        <div class="user-menu-divider"></div>
                                    }

                                    if (canImport || canStock)
                                    {
                                        <div class="user-menu-header">Kho hàng</div>

                                        if (canImport)
                                        {
                                            <a href="@Url.Action("Create", "NhapHang", new { area = "Kho" })" class="user-menu-item">
                                                <i class="bi bi-box-seam"></i>
                                                Tạo phiếu nhập
                                            </a>
                                        }

                                        if (canStock)
                                        {
                                            <a href="@Url.Action("Index", "TonKho", new { area = "Kho" })" class="user-menu-item">
                                                <i class="bi bi-boxes"></i>
                                                Báo cáo tồn kho
                                            </a>
                                        }

                                        if (canManageSupplier)
                                        {
                                            <a href="@Url.Action("Index", "NhaCungCap", new { area = "Kho" })" class="user-menu-item">
                                                <i class="bi bi-truck"></i>
                                                QL Nhà cung cấp
                                            </a>
                                        }
                                    }
                                }

                                @if (role == "Admin")
                                {
                                    <div class="user-menu-header">Quản trị</div>
                                    <a href="@Url.Action("Index", "NhanVien", new { area = "Admin" })" class="user-menu-item">
                                        <i class="bi bi-people"></i>
                                        QL Nhân viên
                                    </a>
                                    <a href="@Url.Action("Index", "PhanQuyen", new { area = "Admin" })" class="user-menu-item">
                                        <i class="bi bi-shield-lock"></i>
                                        Phân quyền
                                    </a>
                                    <a href="@Url.Action("Index", "SanPham", new { area = "Admin" })" class="user-menu-item">
                                        <i class="bi bi-phone"></i>
                                        QL Sản phẩm
                                    </a>
                                    <div class="user-menu-divider"></div>
                                    <a href="@Url.Action("Index", "BanHang", new { area = "NhanVien" })" class="user-menu-item">
                                        <i class="bi bi-shop"></i>
                                        Vào trang POS
                                    </a>
                                }

                                <div class="user-menu-divider"></div>
                                <a href="@Url.Action("Logout", "Account", new { area = "" })" class="user-menu-item danger">
                                    <i class="bi bi-box-arrow-right"></i>
                                    Đăng xuất
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn-neon">
                            <i class="bi bi-person"></i>
                            <span>Đăng nhập</span>
                        </a>
                    }
                </div>



            </div>
        </div>
    </nav>


    <div class="container body-content mt-4">
        @RenderBody()

        <footer class="bg-dark text-light mt-5 pt-4 pb-3">
            <div class="container">
                <div class="row">
                    <!-- Giới thiệu -->
                    <div class="col-md-4 mb-3">
                        <h5 class="fw-bold">Cửa hàng điện thoại</h5>
                        <p>
                            Mang đến những chiếc điện thoại và thiết bị công nghệ chất lượng cao với giá cả hợp lý.
                        </p>
                    </div>

                    <!-- Liên kết nhanh -->
                    <div class="col-md-4 mb-3">
                        <h5 class="fw-bold">Liên kết nhanh</h5>
                        <ul class="list-unstyled">
                            <li>
                                @Html.ActionLink("Trang chủ", "Index", "Home", null, new { @class = "nav-link text-light text-decoration-none" })
                            </li>
                            <li>
                                @Html.ActionLink("Sản phẩm", "Index", "Product", null, new { @class = "nav-link text-light text-decoration-none" })
                            </li>
                            <li>
                                @Html.ActionLink("Giỏ hàng", "Index", "Cart", null, new { @class = "nav-link text-light text-decoration-none" })
                            </li>
                        </ul>
                    </div>

                </div>
                <hr class="border-secondary">
                <div class="text-center">
                    <small>&copy; 2025 . All rights reserved.</small>
                </div>
            </div>
        </footer>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @Scripts.Render("~/bundles/jquery")

    @RenderSection("scripts", required: false)

</body>
</html>